{
  "name": "devmenu",
  "version": "1.0.4",
  "description": "A terminal UI to browse and run categorized shell commands, search the whole list, and keep everything in one place instead of hunting through package.json, readmes, and random docs.",
  "author": "Marbin Karaus (https://github.com/marbinkaraus)",
  "homepage": "https://github.com/marbinkaraus/devmenu",
  "bugs": "https://github.com/marbinkaraus/devmenu/issues",
  "license": "MIT",
  "type": "module",
  "main": "cli.js",
  "bin": {
    "devmenu": "cli.js"
  },
  "files": [
    "LICENSE",
    "README.md",
    "cli.js",
    "devmenu.example.yaml",
    "devmenu.example.json"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "bun run scripts/build-cli.ts",
    "prepublishOnly": "bun run build",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "dev": "bun run src/entrypoints/cli.tsx",
    "devmenu": "bun run src/entrypoints/cli.tsx",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marbinkaraus/devmenu.git"
  },
  "keywords": [
    "cli",
    "command-menu",
    "developer-tools",
    "devmenu",
    "ink",
    "json",
    "project",
    "react",
    "shell",
    "terminal",
    "tui",
    "yaml",
    "command-browser",
    "command-picker"
  ],
  "dependencies": {
    "cfonts": "^3.3.1",
    "chalk": "^5.6.2",
    "figures": "^6.1.0",
    "ink-text-input": "^6.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "^1.3.11",
    "@types/react": "^19.2.14",
    "ink": "^6.8.0",
    "ink-big-text": "^2.0.0",
    "react": "^19.2.4",
    "react-devtools-core": "^7.0.1",
    "typescript": "^5.7.2",
    "yaml": "^2.8.3"
  }
}
